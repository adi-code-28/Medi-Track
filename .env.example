# Backend
DATABASE_URL=sqlite:///./meditrack.db
SECRET_KEY=change-me-to-a-long-random-string-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# AI (optional — app works without these using demo/fallback responses)
GEMINI_API_KEY=
OPENAI_API_KEY=
AI_PROVIDER=gemini

# Frontend (copy to frontend/.env)
VITE_API_URL=http://localhost:8000
